# ---- Server ----
PORT=3000
# Public HTTPS base URL of this app (used for OAuth redirect, custom page, webhooks)
APP_BASE_URL=https://your-app.onrender.com

# ---- GoHighLevel Marketplace app (from the developer portal → My Apps) ----
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
# Shared "SSO Key" from the app's Custom Page settings (used to decrypt the postMessage payload)
GHL_SSO_KEY=
# OAuth redirect URL registered on the app; must equal {APP_BASE_URL}/oauth/callback
GHL_REDIRECT_URI=https://your-app.onrender.com/oauth/callback
# GHL API host (v2)
GHL_API_BASE=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28

# ---- Anthropic (invoice extraction) ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Database ----
# Postgres in production; a local SQLite file is fine for development.
DATABASE_URL=postgresql://user:pass@localhost:5432/ghl_invoice

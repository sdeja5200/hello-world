// Prisma schema — multi-tenant token/installation store.
// Production: Postgres. For local dev you can switch `provider` to "sqlite"
// and DATABASE_URL to "file:./dev.db".

generator client {
  provider      = "prisma-client-js"
  // Pin engine targets explicitly. On Debian-slim Docker images Prisma's
  // libssl auto-detection can fail and bundle the wrong (openssl-1.1.x)
  // query engine, which then fails to load at runtime and crashes the app
  // before it can listen. `debian-openssl-3.0.x` matches node:22-slim
  // (Debian 12 / OpenSSL 3.x); `native` keeps local dev working.
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// One row per GHL install (a sub-account/location, or an agency/company).
/// Tokens are short-lived; `expiresAt` drives proactive refresh.
model Installation {
  id            String   @id @default(cuid())
  /// "Location" (sub-account) or "Company" (agency) install.
  userType      String
  ghlCompanyId  String?
  ghlLocationId String?  @unique
  accessToken   String
  refreshToken  String
  expiresAt     DateTime
  scope         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([ghlCompanyId])
}
